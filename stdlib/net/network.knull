// EXAMPLE
// =============================================================================

fn main() {
    println("=== KNULL NETWORKING STACK ===")
    println("")
    
    // HTTP Server
    let mut server = HttpServer::new(SocketAddr::new_ip("0.0.0.0", 8080));
    server.get("/api/hello", |req| {
        HttpResponse::new(200, "OK")
    });
    server.post("/api/echo", |req| {
        HttpResponse::new(200, "OK")
    });
    println("HTTP Server ready on port 8080")
    
    // HTTP Client
    let client = HttpClient::new();
    let response = client.get("https://example.com".to_string());
    println("HTTP Client: ", if response.is_ok() { "OK" } else { "Failed" })
    
    // WebSocket
    let ws = WebSocket::connect("wss://echo.websocket.org".to_string());
    println("WebSocket: ", if ws.is_ok() { "Connected" } else { "Failed" })
    
    // DNS Resolver
    let resolver = DnsResolver::new();
    let ip = resolver.resolve_ipv4("google.com".to_string());
    println("DNS: ", ip.unwrap_or("Failed".to_string()))
    
    // TLS
    let connector = TlsConnector::new();
    println("TLS: Ready")
    
    // Connection Pool
    println("Connection Pool: Ready")
    
    // Load Balancer
    let mut lb = LoadBalancer::new(BalanceStrategy::RoundRobin);
    lb.add_endpoint(Backend { address: SocketAddr::new_ip("10.0.0.1", 80), weight: 100, connections: 0 });
    lb.add_endpoint(Backend { address: SocketAddr::new_ip("10.0.0.2", 80), weight: 100, connections: 0 });
    println("Load Balancer: Ready")
    
    // Reverse Proxy
    let proxy = ReverseProxy::new();
    proxy.add_backend(SocketAddr::new_ip("10.0.0.1", 80), 100);
    proxy.add_backend(SocketAddr::new_ip("10.0.0.2", 80), 100);
    println("Reverse Proxy: Ready")
    
    println("")
    println("=== ALL NETWORKING SYSTEMS OPERATIONAL ===")
}
