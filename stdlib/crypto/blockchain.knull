// =============================================================================
// LAYER 2 - STATE CHANNELS
// =============================================================================

pub struct StateChannel {
    participants: Vec<Address>,
    state: u64,
    nonce: u64,
    is_open: bool,
}

impl StateChannel {
    pub fn new(participants: Vec<Address>) -> StateChannel {
        StateChannel { 
            participants, 
            state: 0, 
            nonce: 0, 
            is_open: true 
        }
    }
    
    pub fn update_state(&mut self, new_state: u64, signatures: Vec<Signature>) -> Result<()> {
        if signatures.len() != self.participants.len() {
            return Err("Need all signatures".to_string());
        }
        
        self.state = new_state;
        self.nonce = self.nonce + 1;
        Ok(())
    }
    
    pub fn close(&mut self) -> u64 {
        self.is_open = false;
        self.state
    }
}

// =============================================================================
// PLASMA
// =============================================================================

pub struct PlasmaChain {
    root_chain: Address,
    child_chain: Address,
    deposits: Map<Address, u64>,
    exit_queue: Vec<Exit>,
}

pub struct Exit {
    owner: Address,
    amount: u64,
    timestamp: u64,
}

impl PlasmaChain {
    pub fn new(root_chain: Address) -> PlasmaChain {
        PlasmaChain { 
            root_chain, 
            child_chain: Address::zero(), 
            deposits: Map::new(), 
            exit_queue: Vec::new() 
        }
    }
    
    pub fn deposit(&mut self, depositor: Address, amount: u64) {
        let current = self.deposits.get(depositor).unwrap_or(0);
        self.deposits.insert(depositor, current + amount);
    }
    
    pub fn start_exit(&mut self, owner: Address, amount: u64) {
        self.exit_queue.push(Exit {
            owner,
            amount,
            timestamp: 0,
        });
    }
}

