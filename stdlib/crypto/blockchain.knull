    let alice_addr = Address::from_public_key(&alice_pub);
    let bob_addr = Address::zero();
    
    println("Alice address: ", alice_addr.to_hex())
    
    // Create transaction
    let mut tx = Transaction::new(alice_addr, bob_addr, 100);
    tx.sign(&alice_priv);
    println("Transaction signed")
    
    // Smart contract
    let code = vec![0x60, 0x80, 0x60, 0x40, 0x52]; // Simple bytecode
    let mut contract = Contract::new(code);
    contract.deploy(alice_addr, Vec::new());
    println("Smart contract deployed")
    
    // Consensus options
    let pow = ProofOfWork::new(u256::from(1));
    let pos = ProofOfStake::new();
    let dpos = DPoS::new();
    let pbft = PBFT::new();
    println("Consensus mechanisms: PoW, PoS, DPoS, PBFT")
    
    // DEX
    let token_a = Address::zero();
    let token_b = Address::zero();
    let mut dex = DEX::new(token_a, token_b);
    dex.add_liquidity(alice_addr, 1000, 2000);
    let price = dex.get_price(token_a);
    println("DEX price: ", price)
    
    // NFT
    let mut nft = NFTContract::new("Knull NFT".to_string(), "KNFT".to_string());
    nft.mint(alice_addr, 1, NFTMetadata {
        name: "First Knull NFT".to_string(),
        description: "Historic first NFT".to_string(),
        image: "".to_string(),
        attributes: Vec::new(),
    });
    println("NFT minted: #1")
    
    // DAO
    let mut dao = DAO::new();
    dao.add_member(alice_addr, 100);
    let proposal_id = dao.create_proposal(alice_addr, "Increase treasury".to_string());
    dao.vote(alice_addr, proposal_id, true);
    println("DAO proposal created: #", proposal_id)
    
    // Layer 2
    let participants = vec![alice_addr, bob_addr];
    let channel = StateChannel::new(participants);
    println("State channel opened")
    
    // Sharding
    let shard_manager = ShardManager::new(16);
    println("Sharding: 16 shards")
    
    println("")
    println("Features:")
    println("  - Blockchain core with PoW/PoS/DPoS/PBFT")
    println("  - Smart contracts")
    println("  - EVM compatibility")
    println("  - P2P networking")
    println("  - Merkle trees")
    println("  - Layer 2 (State channels, Plasma)")
    println("  - Sharding")
    println("  - Decentralized Exchange (AMM)")
    println("  - NFTs")
    println("  - DAOs")
    println("")
    println("=== BLOCKCHAIN FRAMEWORK READY ===")
}
