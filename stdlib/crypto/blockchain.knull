// =============================================================================
// WORLD STATE
// =============================================================================

pub struct WorldState {
    accounts: Map<Address, Account>,
}

pub struct Account {
    nonce: u64,
    balance: u64,
    code_hash: Hash,
    storage_root: Hash,
}

impl WorldState {
    pub fn new() -> WorldState {
        WorldState { accounts: Map::new() }
    }
    
    pub fn get_account(&self, address: &Address) -> Option<&Account> {
        self.accounts.get(*address)
    }
    
    pub fn get_balance(&self, address: &Address) -> u64 {
        if let Some(account) = self.accounts.get(*address) {
            account.balance
        } else {
            0
        }
    }
    
    pub fn apply_transaction(&mut self, tx: &Transaction) {
        let from_account = self.accounts.get_mut(tx.from);
        if let Some(account) = from_account {
            account.balance = account.balance - tx.value;
            account.nonce = account.nonce + 1;
        }
        
        let to_account = self.accounts.get_mut(tx.to);
        if let Some(account) = to_account {
            account.balance = account.balance + tx.value;
        }
    }
    
    pub fn create_account(&mut self, address: Address) {
        self.accounts.insert(address, Account {
            nonce: 0,
            balance: 0,
            code_hash: Hash::zero(),
            storage_root: Hash::zero(),
        });
    }
}

// =============================================================================
// MEMPOOL
// =============================================================================

pub struct Mempool {
    transactions: Vec<Transaction>,
    by_sender: Map<Address, Vec<Transaction>>,
}

impl Mempool {
    pub fn new() -> Mempool {
        Mempool { 
            transactions: Vec::new(), 
            by_sender: Map::new() 
        }
    }
    
    pub fn add_transaction(&mut self, tx: Transaction) {
        self.transactions.push(tx.clone());
        
        let sender_txs = self.by_sender.get_mut(tx.from);
        if let Some(txs) = sender_txs {
            txs.push(tx);
        } else {
            self.by_sender.insert(tx.from, vec![tx]);
        }
    }
    
    pub fn get_transactions(&self, max_gas: u64) -> Vec<Transaction> {
        // Get transactions sorted by gas price
        self.transactions.clone()
    }
    
    pub fn remove(&mut self, tx_hash: Hash) {
        // Remove transaction from mempool
    }
}

