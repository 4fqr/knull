                difficulty: 1,
                nonce: 0,
                state_root: Hash::zero(),
                receipts_root: Hash::zero(),
            },
            transactions: Vec::new(),
            hash: Hash::zero(),
        }
    }
    
    pub fn compute_hash(&self) -> Hash {
        // SHA3-256 of header + transactions
        Hash::zero()
    }
}

