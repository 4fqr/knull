// =============================================================================
// CONSENSUS MECHANISMS
// =============================================================================

pub trait Consensus {
    fn verify_block(&self, block: &Block, parent: &Block) -> bool;
    fn mine_block(&self, header: &mut BlockHeader);
    fn verify_transaction(&self, tx: &Transaction, state: &WorldState) -> bool;
}

// Proof of Work
pub struct ProofOfWork {
    target: u256,
}

impl Consensus for ProofOfWork {
    fn verify_block(&self, block: &Block, parent: &Block) -> bool {
        // Check hash meets target
        true
    }
    
    fn mine_block(&self, header: &mut BlockHeader) {
        header.nonce = 0;
        loop {
            let hash = Self::hash_header(header);
            if Self::check_difficulty(&hash, &self.target) {
                break;
            }
            header.nonce = header.nonce + 1;
        }
    }
    
    fn verify_transaction(&self, tx: &Transaction, state: &WorldState) -> bool {
        let balance = state.get_balance(&tx.from);
        balance >= tx.value + tx.gas_limit * tx.gas_price
    }
}

// Proof of Stake
pub struct ProofOfStake {
    min_stake: u64,
    validators: Map<Address, u64>,
}

impl Consensus for ProofOfStake {
    fn verify_block(&self, block: &Block, parent: &Block) -> bool {
        true
    }
    
    fn mine_block(&self, _header: &mut BlockHeader) {
        // PoS doesn't mine, it proposes
    }
    
    fn verify_transaction(&self, tx: &Transaction, state: &WorldState) -> bool {
        true
    }
}

