pub struct Transaction {
    nonce: u64,
    from: Address,
    to: Address,
    value: u64,
    gas_price: u64,
    gas_limit: u64,
    data: Vec<u8>,
    signature: Signature,
    hash: Hash,
}

impl Transaction {
    pub fn new(from: Address, to: Address, value: u64) -> Transaction {
        Transaction {
            nonce: 0,
            from,
            to,
            value,
            gas_price: 0,
            gas_limit: 0,
            data: Vec::new(),
            signature: Signature::zero(),
            hash: Hash::zero(),
        }
    }
    
    pub fn sign(&mut self, private_key: &PrivateKey) {
        self.signature = private_key.sign(&self.hash());
    }
    
    pub fn verify_signature(&self) -> bool {
        self.signature.verify(&self.from, &self.hash())
    }
    
    pub fn hash(&self) -> Hash {
        // Keccak-256
        Hash::zero()
    }
}

