// =============================================================================
// BLOCKCHAIN CORE
// =============================================================================

pub struct Blockchain {
    genesis_block: Block,
    chain: Vec<Block>,
    state: WorldState,
    consensus: Box<dyn Consensus>,
    mempool: Mempool,
    network: P2PNetwork,
}

impl Blockchain {
    pub fn new(consensus: impl Consensus) -> Blockchain {
        let genesis = Block::genesis();
        
        Blockchain {
            genesis_block: genesis.clone(),
            chain: vec![genesis],
            state: WorldState::new(),
            consensus: Box::new(consensus),
            mempool: Mempool::new(),
            network: P2PNetwork::new(),
        }
    }
    
    pub fn add_block(&mut self, block: Block) -> Result<()> {
        // Verify block
        if !self.consensus.verify_block(&block, &self.chain.last().unwrap()) {
            return Err("Invalid block".to_string());
        }
        
        // Apply state changes
        for tx in &block.transactions {
            self.state.apply_transaction(tx);
        }
        
        self.chain.push(block);
        Ok(())
    }
    
    pub fn add_transaction(&mut self, tx: Transaction) -> Result<()> {
        // Verify transaction
        if !tx.verify_signature() {
            return Err("Invalid signature".to_string());
        }
        
        self.mempool.add_transaction(tx);
        Ok(())
    }
    
    pub fn get_balance(&self, address: Address) -> u64 {
        self.state.get_balance(&address)
    }
    
    pub fn get_transaction(&self, hash: Hash) -> Option<Transaction> {
        let i = 0
        while i < self.chain.len() {
            let j = 0
            while j < self.chain[i].transactions.len() {
                if self.chain[i].transactions[j].hash == hash {
                    return Some(self.chain[i].transactions[j].clone());
                }
                j = j + 1;
            }
            i = i + 1;
        }
        None
    }
    
    pub fn get_block(&self, hash: Hash) -> Option<Block> {
        let i = 0
        while i < self.chain.len() {
            if self.chain[i].hash == hash {
                return Some(self.chain[i].clone());
            }
            i = i + 1;
        }
        None
    }
}

