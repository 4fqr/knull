        }
    }
}

// =============================================================================
// OPTIMIZERS
// =============================================================================

pub trait Optimizer {
    fn step(&mut self, parameters: &mut Vec<&mut Tensor<f32>>, gradients: &Vec<Tensor<f32>>);
}

pub struct SGD {
    lr: f32,
    momentum: f32,
}

impl SGD {
    pub fn new(lr: f32) -> SGD {
        SGD { lr, momentum: 0.9 }
    }
}

impl Optimizer for SGD {
    fn step(&mut self, parameters: &mut Vec<&mut Tensor<f32>>, gradients: &Vec<Tensor<f32>>) {
        let i = 0
        while i < parameters.len() {
            let j = 0
            while j < parameters[i].data.len() {
                parameters[i].data[j] = parameters[i].data[j] - self.lr * gradients[i].data[j];
                j = j + 1;
            }
            i = i + 1;
        }
    }
}

pub struct Adam {
    lr: f32,
    beta1: f32,
    beta2: f32,
    epsilon: f32,
    m: Vec<Tensor<f32>>,
    v: Vec<Tensor<f32>>,
    t: u32,
}

impl Adam {
    pub fn new(lr: f32) -> Adam {
        Adam { 
            lr, 
            beta1: 0.9, 
            beta2: 0.999, 
            epsilon: 1e-8,
            m: Vec::new(),
            v: Vec::new(),
            t: 0,
        }
    }
}

impl Optimizer for Adam {
    fn step(&mut self, parameters: &mut Vec<&mut Tensor<f32>>, gradients: &Vec<Tensor<f32>>) {
        self.t = self.t + 1;
        // Adam update rule
    }
}

// =============================================================================
// LOSS FUNCTIONS
// =============================================================================

pub fn mse_loss(pred: &Tensor<f32>, target: &Tensor<f32>) -> f32 {
    let diff = pred.add(&target.mul(&Tensor::new(vec![-1.0], Device::CPU)));
    let squared = diff.mul(&diff);
    let mean = squared.sum(None);
    mean.data[0]
}

pub fn cross_entropy_loss(pred: &Tensor<f32>, target: &Tensor<f32>) -> f32 {
    // Cross entropy: -sum(y * log(p))
    let log_pred = pred.log();
    let loss = target.mul(&log_pred);
    -(loss.sum(None).data[0])
}

pub fn binary_cross_entropy(pred: &Tensor<f32>, target: &Tensor<f32>) -> f32 {
    // Binary cross entropy
    let epsilon = 1e-7;
    let clipped = pred.sigmoid();
    let loss = target.mul(&clipped.log()) + (Tensor::ones(target.shape().clone(), Device::CPU).add(&clipped.mul(&Tensor::new(vec![-1.0], Device::CPU)))).log();
    -(loss.sum(None).data[0])
}

