pub struct Dataset {
    data: Tensor<f32>,
    labels: Tensor<f32>,
}

impl Dataset {
    pub fn len(&self) -> u32 {
        self.data.size()
    }
    
    pub fn get(&self, idx: u32) -> (Tensor<f32>, Tensor<f32>) {
        // Get item by index
        (self.data.clone(), self.labels.clone())
    }
}

pub struct DataLoader {
    dataset: Dataset,
    batch_size: u32,
    shuffle: bool,
}

impl DataLoader {
    pub fn new(dataset: Dataset, batch_size: u32, shuffle: bool) -> DataLoader {
        DataLoader { dataset, batch_size, shuffle }
    }
    
    pub fn iter(&self) -> DataLoaderIter {
        DataLoaderIter { 
            loader: self, 
            index: 0 
        }
    }
}

pub struct DataLoaderIter<'a> {
    loader: &'a DataLoader,
    index: u32,
}

impl<'a> Iterator for DataLoaderIter<'a> {
    type Item = (Tensor<f32>, Tensor<f32>);
    
    fn next(&mut self) -> Option<Self::Item> {
        if self.index >= self.loader.dataset.len() {
            None
        } else {
            let item = self.loader.dataset.get(self.index);
            self.index = self.index + 1;
            Some(item)
        }
    }
}

