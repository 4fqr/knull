// =============================================================================
// EXAMPLE
// =============================================================================

fn main() {
    println("=== KNULL AI/ML FRAMEWORK ===")
    println("")
    
    // Create tensor
    let x = Tensor::new(vec![3, 4], Device::CPU);
    println("Created tensor: shape={:?}", x.shape())
    
    // Matrix multiplication
    let a = Tensor::randn(vec![2, 3], Device::CPU);
    let b = Tensor::randn(vec![3, 2], Device::CPU);
    let c = a.matmul(&b);
    println("Matrix multiply: shape={:?}", c.shape())
    
    // Neural network
    let mut model = Sequential::new();
    model.add(Linear::new(784, 128));
    model.add(Linear::new(128, 10));
    
    let input = Tensor::randn(vec![1, 784], Device::CPU);
    let output = model.forward(&input);
    println("MLP output: shape={:?}", output.shape())
    
    // CNN
    let cnn = CNN::new();
    cnn.add_conv(3, 64, 3);
    cnn.add_conv(64, 128, 3);
    let cnn_input = Tensor::randn(vec![1, 3, 224, 224], Device::CPU);
    let cnn_output = cnn.forward(&cnn_input);
    println("CNN output: shape={:?}", cnn_output.shape())
    
    // Optimizer
    let mut sgd = SGD::new(0.01);
    println("SGD optimizer created")
    
    // DataLoader
    let dataset = Dataset { 
        data: Tensor::randn(vec![1000, 784], Device::CPU),
        labels: Tensor::zeros(vec![1000], Device::CPU),
    };
    let mut loader = DataLoader::new(dataset, 32, true);
    println("DataLoader: {} batches", 1000 / 32)
    
    // Loss functions
    let pred = Tensor::randn(vec![10], Device::CPU);
    let target = Tensor::zeros(vec![10], Device::CPU);
    let loss = mse_loss(&pred, &target);
    println("MSE Loss: ", loss)
    
    // RL Agent
    let agent = Agent::new(4, 2);
    println("RL Agent: state_size=4, action_size=2")
    
    // Computer Vision
    let yolo = YOLO::new(80);
    let image = Tensor::randn(vec![1, 3, 416, 416], Device::CPU);
    let detections = yolo.detect(&image);
    println("YOLO detections: {} objects", detections.len())
    
    println("")
    println("Features:")
    println("  - Tensor operations")
    println("  - Neural networks (MLP, CNN, RNN)")
    println("  - Transformers/Attention")
    println("  - Optimizers (SGD, Adam)")
    println("  - Loss functions")
    println("  - DataLoaders")
    println("  - NLP (Embedding, Tokenizer)")
    println("  - Computer Vision (ResNet, VGG, YOLO)")
    println("  - Reinforcement Learning")
    println("  - GPU compute support")
    println("")
    println("=== AI/ML FRAMEWORK READY ===")
}
