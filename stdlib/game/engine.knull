}

// =============================================================================
// MATH UTILITIES
// =============================================================================

struct Vec2 { x: f32, y: f32 }
struct Vec3 { x: f32, y: f32, z: f32 }
struct Vec4 { x: f32, y: f32, z: f32, w: f32 }
struct Mat4 { data: [f32; 16] }
struct Rect { x: f32, y: f32, w: f32, h: f32 }
struct Color { r: f32, g: f32, b: f32, a: f32 }

struct Camera2D { x: f32, y: f32, zoom: f32 }
struct GamepadState { connected: bool, buttons: [bool; 16], axes: [f32; 6] }

const KEY_ESCAPE: KeyCode = KeyCode(27)
const COLOR_BLACK: Color = Color { r: 0, g: 0, b: 0, a: 1 }
const COLOR_WHITE: Color = Color { r: 1, g: 1, b: 1, a: 1 }

fn time_millis() -> i64 { 0 }
fn min_f(a: f32, b: f32) -> f32 { if a < b { a } else { b } }

struct AudioContext { device: u32 }
struct AudioBuffer { samples: Vec<f32> }
struct AudioSource { }

// =============================================================================
// MAIN EXAMPLE
// =============================================================================

fn main() {
    println("=== KNULL GAME ENGINE ===")
    println("")
    
    // Create engine
    let mut engine = Engine::new();
    engine.init(1920, 1080);
    
    // Load assets
    engine.assets.load_texture("player", "assets/player.png");
    engine.assets.load_sound("jump", "assets/jump.wav");
    
    // Create scene
    let mut scene = Scene::new("main");
    
    // Create player entity
    let mut player = Entity::new("player");
    player.add_component(Transform { 
        position: Vec2 { x: 100, y: 100 }, 
        rotation: 0, 
        scale: Vec2 { x: 1, y: 1 } 
    });
    player.add_component(SpriteRenderer { 
        sprite: Sprite::new("assets/player.png"), 
        color: COLOR_WHITE, 
        layer: 0 
    });
    
    let rb = RigidBody {
        position: Vec2 { x: 100, y: 100 },
        velocity: Vec2 { x: 0, y: 0 },
        acceleration: Vec2 { x: 0, y: 0 },
        mass: 1.0,
        inverse_mass: 1.0,
        restitution: 0.5,
        friction: 0.3,
        shape: ColliderShape::Rectangle { width: 32, height: 32 },
        body_type: BodyType::Dynamic,
    };
    player.add_component(RigidBodyComponent { body: rb });
    
    scene.add_entity(player);
    
    // Run game loop
    // engine.run();
    
    println("Game engine initialized!")
    println("Components loaded:")
    println("  - 2D Renderer")
    println("  - 3D Renderer")
    println("  - Physics Engine")
    println("  - Audio Engine")
    println("  - Input System")
    println("  - Scene Manager")
    println("  - Particle System")
    println("  - UI System")
    println("")
    println("=== GAME ENGINE READY ===")
}
