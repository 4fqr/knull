// =============================================================================
// KNULL TEST FRAMEWORK SELF-TESTS
// =============================================================================
// Tests core language features: arithmetic, strings, arrays, closures, HOF.
// Run with: knull run tests/test_main.knull

fn check(cond, msg) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
    }
}

println("=== Knull Core Language Tests ===")
println("")

// --- Arithmetic ---
println("-- Arithmetic --")
check(1 + 1 == 2,        "int add")
check(10 - 3 == 7,       "int sub")
check(6 * 7 == 42,       "int mul")
check(10 / 2 == 5,       "int div")
check(10 % 3 == 1,       "int mod")
check(2 * (3 + 4) == 14, "parens precedence")

// --- Strings ---
println("")
println("-- Strings --")
check("hello" + " world" == "hello world", "string concat")
check(len("knull") == 5,                   "string len")

// --- Booleans ---
println("")
println("-- Booleans --")
check(true == true,   "true == true")
check(false == false, "false == false")
check(true != false,  "true != false")
check(!false == true, "not false")

// --- Comparisons ---
println("")
println("-- Comparisons --")
check(5 > 3,   "5 > 3")
check(3 < 5,   "3 < 5")
check(5 >= 5,  "5 >= 5")
check(5 <= 5,  "5 <= 5")
check(5 != 4,  "5 != 4")

// --- Variables ---
println("")
println("-- Variables --")
let x = 42
check(x == 42, "let binding")
let greeting = "hi"
check(greeting == "hi", "string binding")
let flag = true
check(flag, "bool binding")

// --- If / else ---
println("")
println("-- Control flow --")
let a = 10
let b = 20
let bigger = 0
if a > b {
    bigger = a
} else {
    bigger = b
}
check(bigger == 20, "if/else: pick bigger value")

// --- While loop ---
let counter = 0
let wi = 0
while wi < 5 {
    counter = counter + wi
    wi = wi + 1
}
check(counter == 10, "while: sum 0..4 == 10")

// --- Arrays ---
println("")
println("-- Arrays --")
let arr = [10, 20, 30, 40, 50]
check(len(arr) == 5, "array len == 5")
check(arr[0] == 10,  "arr[0] == 10")
check(arr[4] == 50,  "arr[4] == 50")

let nums = [1, 2, 3]
let nums2 = push(nums, 4)
check(len(nums2) == 4, "push returns larger array")
check(nums2[3] == 4,   "pushed value is 4")

// --- Functions ---
println("")
println("-- Functions --")
fn square(n) {
    return n * n
}
check(square(5) == 25, "square(5) == 25")
check(square(0) == 0,  "square(0) == 0")

fn mymax(p, q) {
    if p > q {
        return p
    }
    return q
}
check(mymax(3, 7) == 7, "mymax(3,7) == 7")
check(mymax(9, 2) == 9, "mymax(9,2) == 9")

// --- Lambdas ---
println("")
println("-- Lambdas / HOF --")
let double = fn(x) { return x * 2 }
check(double(6) == 12, "lambda: double(6) == 12")

let values = [1, 2, 3, 4, 5]
let doubled = map(values, fn(x) { return x * 2 })
check(doubled[0] == 2,  "map: first element doubled")
check(doubled[4] == 10, "map: last element doubled")

let evens = filter(values, fn(x) { return x % 2 == 0 })
check(len(evens) == 2,  "filter: 2 evens in 1..5")
check(evens[0] == 2,    "filter: first even is 2")

let total = reduce(values, fn(acc, x) { return acc + x }, 0)
check(total == 15, "reduce: sum 1..5 == 15")

let product = reduce(values, fn(acc, x) { return acc * x }, 1)
check(product == 120, "reduce: product 1..5 == 120")

// --- Closures ---
println("")
println("-- Closures --")
fn make_adder(n) {
    return fn(x) { return x + n }
}
let add10 = make_adder(10)
check(add10(5) == 15, "closure: add10(5) == 15")
check(add10(0) == 10, "closure: add10(0) == 10")

// --- Recursion ---
println("")
println("-- Recursion --")
fn fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
check(fib(0) == 0,   "fib(0) == 0")
check(fib(1) == 1,   "fib(1) == 1")
check(fib(10) == 55, "fib(10) == 55")

// --- Null ---
println("")
println("-- Null --")
let nothing = null
check(nothing == null, "null == null")
check(nothing != 42,   "null != 42")

println("")
println("=== All tests complete ===")
