// =============================================================================
// KNULL MEMORY TESTS
// =============================================================================
// Tests for memory allocation, read/write, and low-level operations.
// Uses real interpreter builtins: mem_alloc, mem_free, mem_read_u64,
// mem_write_u64, mem_set, mem_copy.
// Run with: knull run tests/test_memory.knull

fn check(cond, msg) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
    }
}

println("=== Knull Memory Tests ===")
println("")

// --- Allocation ---
println("-- Allocation --")
let ptr = mem_alloc(64)
check(ptr != 0, "alloc 64 bytes returns non-zero pointer")

let ptr2 = mem_alloc(1024)
check(ptr2 != 0, "alloc 1024 bytes returns non-zero pointer")
check(ptr != ptr2, "two allocations return different pointers")

// --- Read / Write ---
println("")
println("-- Read / Write --")
mem_write_u64(ptr, 0xDEADBEEF)
check(mem_read_u64(ptr) == 0xDEADBEEF, "write and read u64 value")

mem_write_u64(ptr, 0)
check(mem_read_u64(ptr) == 0, "overwrite with 0")

mem_write_u64(ptr, 999999)
check(mem_read_u64(ptr) == 999999, "write large number")

mem_write_u64(ptr2, 42)
check(mem_read_u64(ptr2) == 42, "second allocation read/write")

// --- mem_set ---
println("")
println("-- mem_set --")
mem_write_u64(ptr, 0xFFFFFFFFFFFFFFFF)
mem_set(ptr, 0, 64)
check(mem_read_u64(ptr) == 0, "mem_set zeros memory")

// --- Free ---
println("")
println("-- Free --")
mem_free(ptr, 64)
mem_free(ptr2, 1024)
println("[PASS] mem_free completed without error")

// --- Multiple allocations ---
println("")
println("-- Multiple allocations --")
let p1 = mem_alloc(8)
let p2 = mem_alloc(8)
let p3 = mem_alloc(8)
mem_write_u64(p1, 111)
mem_write_u64(p2, 222)
mem_write_u64(p3, 333)
check(mem_read_u64(p1) == 111, "p1 holds 111")
check(mem_read_u64(p2) == 222, "p2 holds 222")
check(mem_read_u64(p3) == 333, "p3 holds 333")
mem_free(p1, 8)
mem_free(p2, 8)
mem_free(p3, 8)
println("[PASS] multiple alloc/free cycle")

// --- Allocation sizes ---
println("")
println("-- Allocation sizes --")
let sizes = [1, 8, 16, 64, 256, 512, 1024, 4096]
let si = 0
while si < len(sizes) {
    let sz = sizes[si]
    let p = mem_alloc(sz)
    check(p != 0, "alloc size ok")
    mem_free(p, sz)
    si = si + 1
}

println("")
println("=== Memory tests complete ===")
