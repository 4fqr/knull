// =============================================================================
// KNULL SYSTEM TESTS
// =============================================================================
// Tests for system calls, file I/O, time, and process info.
// Uses real interpreter builtins: getpid, time_millis, sleep_ms,
// file_read, file_write, file_exists, file_remove, env_get.
// Run with: knull run tests/test_sys.knull

fn check(cond, msg) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
    }
}

println("=== Knull System Tests ===")
println("")

// --- Process ---
println("-- Process --")
let pid = getpid()
check(pid > 0, "getpid() > 0")

// --- Time ---
println("")
println("-- Time --")
let t1 = time_millis()
check(t1 > 0, "time_millis() > 0")

sleep_ms(20)

let t2 = time_millis()
check(t2 >= t1, "time increases after sleep")
check(t2 - t1 >= 10, "at least 10ms elapsed after sleep(20)")

// --- File I/O ---
println("")
println("-- File I/O --")
let testfile = "/tmp/knull_test_sys.txt"

file_write(testfile, "hello from knull")
check(file_exists(testfile), "file exists after write")

let content = file_read(testfile)
check(content == "hello from knull", "file content matches")

file_write(testfile, "overwritten content")
let content2 = file_read(testfile)
check(content2 == "overwritten content", "file overwrite works")

file_remove(testfile)
check(!file_exists(testfile), "file deleted successfully")

// --- Multiple file ops ---
println("")
println("-- Multiple file ops --")
let f1 = "/tmp/knull_test_f1.txt"
let f2 = "/tmp/knull_test_f2.txt"
file_write(f1, "file one")
file_write(f2, "file two")
check(file_read(f1) == "file one", "read f1")
check(file_read(f2) == "file two", "read f2")
file_remove(f1)
file_remove(f2)
check(!file_exists(f1), "f1 deleted")
check(!file_exists(f2), "f2 deleted")

// --- Environment ---
println("")
println("-- Environment --")
let path = env_get("PATH")
check(path != null, "PATH env var exists")
check(path != "", "PATH is not empty")

let home = env_get("HOME")
check(home != null, "HOME env var exists")

// Non-existent variable should return null
let fake = env_get("KNULL_FAKE_VAR_XYZ_123")
check(fake == null, "unknown env var returns null")

println("")
println("=== System tests complete ===")
